# =========================
# Core API token
# =========================
ALOR_TOKEN=PUT_YOUR_ALOR_TOKEN_HERE

# =========================
# PostgreSQL (PG_RAW)
# =========================
PG_RAW_HOST=pg_raw
PG_RAW_PORT=5432
PG_RAW_DB=pg_raw
PG_RAW_USER=postgres
PG_RAW_PASSWORD=CHANGE_ME_PG_RAW_PASSWORD

# =========================
# PostgreSQL (PG_DWH)
# =========================
PG_DWH_HOST=pg_dwh
PG_DWH_PORT=5432
PG_DWH_DB=pg_dwh
PG_DWH_USER=postgres
PG_DWH_PASSWORD=CHANGE_ME_PG_DWH_PASSWORD

# =========================
# Prefect DB
# =========================
PREFECT_DB_USER=postgres
PREFECT_DB_PASSWORD=CHANGE_ME_PREFECT_DB_PASSWORD
PREFECT_DB_NAME=prefect
PREFECT_API_URL=http://127.0.0.1:4200/api

# =========================
# MinIO / S3 compatible storage
# =========================
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD
MINIO_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_S3_FORCE_PATH_STYLE=true

# =========================
# Admin UIs
# =========================
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# =========================
# Optional backup script credentials
# =========================
PG_BACKUP_USER=postgres
PG_BACKUP_PASSWORD=CHANGE_ME_PG_BACKUP_PASSWORD
